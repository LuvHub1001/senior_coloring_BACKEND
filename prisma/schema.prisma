generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 전시관 테마
model Theme {
  id               Int      @id @default(autoincrement())
  name             String   @unique
  requiredArtworks Int      @default(0) @map("required_artworks") // 해금에 필요한 완성 작품 수
  imageUrl         String?  @map("image_url") // 테마 배경 이미지 URL
  textColor        String?  @map("text_color") // 화면 타이틀/본문 텍스트 색상
  toggleType       ToggleType @default(LIGHT) @map("toggle_type") // 토글 스타일 (밝은/어두운 배경)
  frameImageUrl    String?  @map("frame_image_url") // 액자 프레임 이미지 URL
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")

  users User[]

  @@map("themes")
}

// 사용자
model User {
  id              String   @id @default(uuid())
  email           String?  @unique
  nickname        String
  avatarUrl       String?  @map("avatar_url")
  statusMessage   String?  @map("status_message")
  provider        String   // kakao, naver
  providerId      String   @map("provider_id")
  role            Role     @default(USER)
  selectedThemeId   Int?     @map("selected_theme_id")
  featuredArtworkId   String?  @unique @map("featured_artwork_id")
  totalCompletedCount Int      @default(0) @map("total_completed_count") // 누적 완성 작품 수 (삭제해도 감소하지 않음)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  selectedTheme  Theme?      @relation(fields: [selectedThemeId], references: [id])
  featuredArtwork Artwork?   @relation("FeaturedArtwork", fields: [featuredArtworkId], references: [id])
  artworks       Artwork[]
  exhibitions    Exhibition[]
  refreshTokens  RefreshToken[]
  communityLikes CommunityLike[]

  @@unique([provider, providerId])
  @@map("users")
}

// 컬러링 도안 (원본 템플릿)
model Design {
  id               Int      @id @default(autoincrement())
  title            String
  category         String
  imageUrl         String   @map("image_url")           // 색칠용 도안 (흑백 윤곽선)
  originalImageUrl String?  @map("original_image_url")  // 원본 컬러 이미지 (미리보기용)
  description      String?
  createdAt        DateTime @default(now()) @map("created_at")

  artworks        Artwork[]
  recommendations Recommendation[]

  @@index([category])
  @@index([category, createdAt]) // 카테고리별 최신순 정렬 최적화
  @@map("designs")
}

// 사용자 작품 (색칠 결과물)
model Artwork {
  id              String        @id @default(uuid())
  userId          String        @map("user_id")
  designId        Int           @map("design_id")
  rootArtworkId   String?       @map("root_artwork_id") // 수정하기로 생성된 경우 최초 원본 작품 ID
  imageUrl        String?       @map("image_url")
  progress        Int           @default(0)
  status          ArtworkStatus @default(IN_PROGRESS)
  isPublic        Boolean       @default(false) @map("is_public") // 커뮤니티 공개 여부
  likeCount       Int           @default(0) @map("like_count") // 좋아요 수 (비정규화)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id])
  design       Design        @relation(fields: [designId], references: [id])
  exhibition   Exhibition?
  featuredBy   User?         @relation("FeaturedArtwork")
  likes        CommunityLike[]

  @@index([userId, status])
  @@index([designId])
  @@index([status, isPublic, likeCount]) // 커뮤니티 인기순 조회
  @@index([status, isPublic, createdAt]) // 커뮤니티 최신순 조회
  @@index([userId, updatedAt])           // 내 작품 목록 정렬 최적화
  @@map("artworks")
}

// 커뮤니티 좋아요
model CommunityLike {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  artworkId String   @map("artwork_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  artwork Artwork @relation(fields: [artworkId], references: [id], onDelete: Cascade)

  @@unique([userId, artworkId])
  @@index([artworkId])
  @@index([createdAt]) // 오늘의 인기 작품 쿼리 최적화
  @@map("community_likes")
}

// 전시 (완성작 공개)
model Exhibition {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  artworkId String   @unique @map("artwork_id")
  title     String
  shareUrl  String?  @map("share_url")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  artwork Artwork @relation(fields: [artworkId], references: [id])

  @@map("exhibitions")
}

// Refresh Token
model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  family    String    @default(uuid()) @map("family") // 토큰 패밀리 (재사용 감지)
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at") // null=활성, 값=사용됨(rotation 완료)
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([family])
  @@map("refresh_tokens")
}

// 공지사항
model Notice {
  id        String   @id @default(uuid())
  title     String
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("notices")
}

// 도안 추천 배너
model Recommendation {
  id        String   @id @default(uuid())
  designId  Int      @map("design_id")
  imageUrl  String   @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")

  design Design @relation(fields: [designId], references: [id])

  @@map("recommendations")
}

enum ArtworkStatus {
  IN_PROGRESS
  COMPLETED
}

enum ToggleType {
  LIGHT
  DARK
}

enum Role {
  USER
  ADMIN
}
